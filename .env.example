# Cron schedule (5-field standard cron).
CRON_SCHEDULE=30 4 * * 1

# Host path to mount as the repos directory.
REPOS_HOST_PATH=/path/to/your/repos

# Path inside the container — keep in sync with REPOS_HOST_PATH above.
REPOS_DIR=/repos

# Uptime Kuma push monitor URL (base URL only; script appends status/msg). Leave empty to disable.
UPTIME_KUMA_URL=

# UID/GID — must match the owner of the host repos directory (run `id` on the host to check).
PUID=1000
PGID=1000

# Timezone for the cron schedule.
TZ=Europe/Berlin

# Run a backup immediately when the container starts.
RUN_ON_STARTUP=true

# Seconds to wait per git operation.
GIT_TIMEOUT=300

# Comma-separated repo directory names to skip entirely (optional).
# IGNORE_REPOS=some-non-existent-repo,some-broken-repo

# Comma-separated directory names that contain repos instead of being repos themselves.
# Each listed folder is recursed one level deep.
# REPO_GROUPS=citra-emu,yuzu-emu

# Comma-separated GitHub org/user names to auto-clone and keep updated.
# Each source gets its own subdirectory under REPOS_HOST_PATH.
# GITHUB_SOURCES=some-org,some-user

# Skip forked repositories when syncing GitHub sources (default: true).
GITHUB_SKIP_FORKS=true

# Skip archived repositories when syncing GitHub sources (default: false).
GITHUB_SKIP_ARCHIVED=false
